{
    "family": "meetverse-livekit-server",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "executionRoleArn": "arn:aws:iam::029377893320:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "livekit-server",
            "image": "029377893320.dkr.ecr.us-east-1.amazonaws.com/meetverse-livekit-server:latest",
            "essential": true,
            "command": [
                "--dev",
                "--bind",
                "0.0.0.0"
            ],
            "portMappings": [
                {
                    "containerPort": 7880,
                    "protocol": "tcp"
                },
                {
                    "containerPort": 7881,
                    "protocol": "udp"
                }
            ],
            "environment": [
                {
                    "name": "LIVEKIT_KEYS",
                    "value": "devkey: supersecretkey123456789123456789"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/meetverse-livekit-server",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs",
                    "awslogs-create-group": "true"
                }
            }
        }
    ]
}